# Waitlist storage — Supabase (server-only keys, never NEXT_PUBLIC)
#
# The `waitlist_signups` table has RLS enabled with no public policies, so it
# is only reachable with the service role key from the server-side API route
# (app/api/waitlist/route.ts via lib/supabaseAdmin.ts). Never expose the
# service role key to the browser.
#
# Table columns: email, role, source, created_at, updated_at.
# role is stored as one of: listener, artist, songwriter_producer, tastemaker.
# Upserts go through the upsert_waitlist_signup() function, which does
# INSERT ... ON CONFLICT (lower(email)) against the unique lower(email) index.
#
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
